{
  "expo": {
    "name": "Crash Asesores",
    "slug": "crash-asesores-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#003366"
    },
    "android": {
      "package": "com.ereza018.crashapp",
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#003366"
      }
    },
    "plugins": [
      ["expo-image-picker", { "photosPermission": "Acceso a fotos necesario" }],
      ["expo-location", { "locationAlwaysPermission": "Ubicación necesaria" }]
    ]
  }
}
