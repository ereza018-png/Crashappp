{
  "expo": {
    "name": "Crash Asesores",
    "slug": "crash-asesores-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#003366"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#003366"
      },
      "package": "com.ereza018.crashapp"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Acceso a fotos necesario."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Ubicación necesaria."
        }
      ]
    ]
  }
}
