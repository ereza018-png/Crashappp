{
  "expo": {
    "name": "Crashito",
    "slug": "crashito",
    "version": "1.0.0",
    "android": {
      "package": "com.ereza018.appcrashnueva",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "splash": {
      "backgroundColor": "#003366"
    },
    "plugins": [
      "expo-location",
      "expo-image-picker",
      "expo-document-picker",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "3687876b-8496-4caf-8083-f29cfc9d7262"
      }
    }
  }
}
