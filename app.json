{
  "expo": {
    "name": "Crash Asesores",
    "slug": "crash-asesores-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "light",
    "ios": { "supportsTablet": true },
    "android": {
      "package": "com.ereza018.crashapp",
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#003366"
      }
    },
    "plugins": [
      ["expo-image-picker", { "photosPermission": "Acceso necesario" }],
      ["expo-location", { "locationAlwaysPermission": "Acceso necesario" }]
    ]
  }
}
