{
  "expo": {
    "name": "Crash Asesores",
    "slug": "crashitc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#003366"
    },
    "android": {
      "package": "com.ereza018.crashapp",
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#003366"
      }
    },
    "extra": {
      "eas": {
        "projectId": "3687876b-8496-4caf-8083-f29cfc9d7262"
      }
    },
    "owner": "crashitc",
    "plugins": [
      ["expo-image-picker", { "photosPermission": "Permiso para cámara." }],
      ["expo-location", { "locationAlwaysPermission": "Permiso para GPS." }]
    ]
  }
}
